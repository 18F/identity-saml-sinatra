# Run the broker app instead of the sample relying party app.
APP_MODE=broker

# Broker SP configuration against Login.gov
BROKER_ASSERTION_CONSUMER_SERVICE_URL=http://localhost:4567/acs
BROKER_ISSUER=urn:gov:gsa:SAML:2.0.profiles:sp:sso:login-gov:aws-quicksight-broker
BROKER_IDP_SSO_TARGET_URL=https://idp.int.identitysandbox.gov/api/saml/auth2026
BROKER_IDP_SLO_TARGET_URL=https://idp.int.identitysandbox.gov/api/saml/logout2026
BROKER_IDP_CERT_FINGERPRINT=
BROKER_IDP_CERT_FINGERPRINT_ALGORITHM=http://www.w3.org/2000/09/xmldsig#sha1

# Secret for signing transient RelayState broker context
BROKER_STATE_SECRET=replace-with-long-random-secret

# Optional default relay state (for example QuickSight deep link) used when
# upstream does not provide one.
# BROKER_DEFAULT_RELAY_STATE=https://us-east-1.quicksight.aws.amazon.com/sn/start

# Optional comma-separated allowlist for relay state prefixes.
# If empty, all relay state values are accepted.
# BROKER_RELAY_STATE_ALLOWLIST_PREFIXES=https://us-east-1.quicksight.aws.amazon.com/,https://quicksight.aws.amazon.com/

# Optional YAML file map for per-user authorization and role assignment.
# If set, unmapped users are denied unless config includes a default section.
# Keep ARNs out of the user map; use logical aws_role keys there.
BROKER_USER_MAP_FILE=config/user_map.yml
# BROKER_USER_MAP_KEYS=email,uuid,name_id

# Optional: inline certificate/key PEM values. If omitted, demo cert/key are used.
# BROKER_SP_CERT=
# BROKER_SP_PRIVATE_KEY=

# AWS assertion minting settings (required for aws_broker_assertion mode)
BROKER_AWS_ROLE_ARN=arn:aws:iam::123456789012:role/quicksight_login_gov_reader
BROKER_AWS_SAML_PROVIDER_ARN=arn:aws:iam::123456789012:saml-provider/quicksight-login-gov-broker
BROKER_AWS_IDP_ENTITY_ID=urn:gov:gsa:SAML:2.0.profiles:sp:sso:login-gov:aws-quicksight-broker
BROKER_AWS_AUDIENCE=urn:amazon:webservices

# Optional JSON map from logical role key -> role ARN used by user_map.yml
# Example: {"reader":"arn:aws:iam::123456789012:role/quicksight_login_gov_reader","author":"arn:aws:iam::123456789012:role/quicksight_login_gov_author"}
# BROKER_AWS_ROLE_ARNS_JSON={"reader":"arn:aws:iam::123456789012:role/quicksight_login_gov_reader"}

# Optional
# BROKER_AWS_ROLE_SESSION_NAME_SOURCE=email
# BROKER_AWS_ROLE_SESSION_NAME_STATIC=quicksight-broker-session
# BROKER_AWS_SESSION_DURATION=3600

# Output mode:
# inspect  -> returns JSON payload after successful ACS processing
# aws_post -> auto POSTs SAMLResponse to AWS sign-in endpoint
# aws_broker_assertion -> mint broker-signed AWS-compatible SAMLResponse
BROKER_OUTPUT_MODE=aws_broker_assertion
AWS_SIGNIN_URL=https://signin.aws.amazon.com/saml
